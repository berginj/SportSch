{
    "version": "2.0",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetricsFilters": true
        }
    },
    "extensions": {
        "http": {
            "routePrefix": "api",
            "maxRequestBodySize": 10485760,
            "cors": {
                "allowedOrigins": [
                    "https://softball.sports.fifthseasonadvisors.com",
                    "https://green-meadow-08081740f.5.azurestaticapps.net",
                    "http://localhost:5173",
                    "http://127.0.0.1:5173"
                ],
                "allowedMethods": [
                    "GET",
                    "POST",
                    "PUT",
                    "PATCH",
                    "DELETE",
                    "OPTIONS"
                ],
                "allowedHeaders": [
                    "Content-Type",
                    "Authorization",
                    "x-league-id",
                    "x-correlation-id"
                ],
                "exposedHeaders": [
                    "X-RateLimit-Limit",
                    "X-RateLimit-Remaining",
                    "X-RateLimit-Reset"
                ],
                "allowCredentials": true,
                "maxAge": 3600
            }
        }
    }
}
